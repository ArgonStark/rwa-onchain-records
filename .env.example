# Phase 1 uses only public, no-key sources — nothing here is required to run.
# Listed for Phase 2+ (keep all keys server-side; never expose to the client bundle).

# Arbitrum RPC for Ostium on-chain funding reads (PairInfos contract).
# Optional — defaults to the public https://arb1.arbitrum.io/rpc. Set a dedicated
# RPC (Alchemy/Infura) for production reliability/rate limits. Server-side only.
# ARBITRUM_RPC_URL=

# Postgres connection string for the persistence layer (Phase 2 Task 3).
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/ewa

# Cross-venue OI/volume (free tier works without a key)
# DEFILLAMA_PRO_KEY=

# Historical OI/funding OHLC
# COINGLASS_API_KEY=

# RWA market structure
# RWA_XYZ_API_KEY=

# Token / spot prices (paid tiers)
# COINGECKO_API_KEY=

# Real XAU spot + equities (premium / basis computation)
# GOLDAPI_KEY=
# FINNHUB_KEY=
