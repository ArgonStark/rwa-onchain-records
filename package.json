{
  "name": "ewa-onchain-records",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev",
    "db:start": "pg_ctl -D .pgdata -l .pgdata/server.log start",
    "db:stop": "pg_ctl -D .pgdata stop",
    "db:status": "pg_ctl -D .pgdata status",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nivo/bar": "^0.99.0",
    "@nivo/bump": "^0.99.0",
    "@nivo/calendar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/stream": "^0.99.0",
    "@nivo/treemap": "^0.99.0",
    "lightweight-charts": "^5.2.0",
    "next": "^15.5.19",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.8",
    "@types/node": "22.15.30",
    "@types/pg": "^8.20.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3"
  }
}
